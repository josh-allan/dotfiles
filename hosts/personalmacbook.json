{
  "os": "macos",
  "packages": {
    "public": ["dot_home", "dot_config_common", "dot_config_macos"],
    "private": []
  },
  "templates": {
    "dot_home/.gitconfig": {
      "user.email": "op://Private/Git/email",
      "user.name": "op://Private/Git/name",
      "user.signingkey": "op://Private/Git/signingkey"
    },
    "dot_home/.zshrc": {
      "user.home": "op://Private/System/home_path"
    },
    "dot_config/.config/fish/config.fish": {
      "opencode.path": "op://Private/OpenCode/bin_path"
    }
  },
  "private_repo": null,
  "skip_paths": []
}

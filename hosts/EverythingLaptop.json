{
  "os": "linux",
  "arch": "aarch64",
  "notes": "Asahi Linux (Arch Linux ARM) on Apple Silicon",
  "packages": {
    "public": ["dot_home", "dot_config_common", "dot_config_linux", "asahi"],
    "private": ["private_user", "opencode", "claude", "augment"],
    "system": [{"pkg": "etc_linux", "target": "/etc"}]
  },
  "asahi_system_packages": [
    "archlinuxarm-keyring",
    "asahi-alarm-keyring",
    "asahi-audio",
    "asahi-fwextract",
    "asahi-meta",
    "asahi-scripts",
    "linux-asahi",
    "m1n1",
    "pipewire-libcamera",
    "speakersafetyd",
    "uboot-asahi"
  ],
  "templates": {
    "dot_home/.gitconfig": {
      "user.email": "op://Personal/Git Email/username",
      "user.name": "op://Personal/user/username",
      "user.signingkey": "op://Personal/Git Signing Key/public key"
    },
    "dot_home/.zshrc": {}
  },
  "ssh_keys": {
    "id_ed25519": {
      "private": "op://Personal/Primary SSH key (id_ed25519) /private key",
      "public": "op://Personal/Primary SSH key (id_ed25519) /public key"
    }
  },
  "private_repo": {
    "url": "git@github.com:josh-allan/private-dots.git",
    "branch": "main"
  },
  "skip_paths": [],
  "compliance": {
    "schemaVersion": 1,
    "packages": { "mode": "expected", "expected": [], "absent": [] },
    "services": { "mode": "expected", "units": [
      {"unit": "mpris-proxy.service", "expectedEnabled": true, "expectedActive": null, "severity": "expected"}
    ] },
    "files": { "mode": "expected", "expected": [] }
  }
}

{
  "os": "macos",
  "packages": {
    "public": ["dot_home", "dot_config_common", "dot_config_macos"],
    "private": ["private_user", "work", "opencode", "claude"]
  },
  "templates": {
    "dot_home/.gitconfig": {
      "user.email": "op://Personal/Git Email/username",
      "user.name": "op://Personal/user/username",
      "user.signingkey": "op://Personal/Git Signing Key/public key"
    },
    "dot_home/.zshrc": {}
  },
  "private_repo": {
    "url": "git@github.com:josh-allan/private-dots.git",
    "branch": "main"
  },
  "skip_paths": []
}

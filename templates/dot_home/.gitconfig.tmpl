[user]
	name = {{user.name}}
	email = {{user.email}}
	signingkey = {{user.signingkey}}
[init]
	defaultBranch = main
[core]
	excludesFile = ~/.gitignore
[gpg]
  program = /usr/local/bin/gpg
[commit]
	gpgsign = true
[url "ssh://git@github.com"]
	insteadOf = https://github.com
[push]
  autoSetupRemote = true
[rebase]
  updateRefs = true
[difftool]
  prompt = false
  trustExitCode = true
[pull]
  ff = only
[tag]
	gpgSign = true
[submodule]
	recurse = true

[user]
	name = {{user.name}}
	email = {{user.email}}
	signingkey = {{user.signingkey}}
[init]
	defaultBranch = main
[core]
	excludesFile = ~/.gitignore
    editor = nvim
    pager = delta
[commit]
	gpgsign = true
[url "ssh://git@github.com"]
	insteadOf = https://github.com
[push]
  autoSetupRemote = true
[rebase]
  updateRefs = true
[difftool]
  prompt = false
  trustExitCode = true
[pull]
  ff = only
[tag]
	gpgSign = true
[submodule]
	recurse = true
[delta]
  navigate = true
  features = decorations
  line-numbers = true
  syntax-theme = Monokai Extended Bright
  dark = true
  hunk-header-decoration-style = ul
  hunk-header-style = line-number file syntax

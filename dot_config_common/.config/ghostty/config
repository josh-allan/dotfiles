# Theme
theme = Catppuccin Mocha

# Font
font-family = JetBrains Mono
font-style = Bold
font-size = 14

# Window
window-width = 200
window-height = 45
window-padding-x = 0
window-padding-y = 0
macos-titlebar-style = transparent

# Background
background-opacity = 0.8
background-blur = 75

# Option key behavior
macos-option-as-alt = true

# --- Move between splits: ctrl+shift + hjkl ---
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# --- Resize splits: alt + hjkl ---
keybind = alt+h=resize_split:left,3
keybind = alt+j=resize_split:down,3
keybind = alt+k=resize_split:up,3
keybind = alt+l=resize_split:right,3

# --- Split Creation ---
keybind = alt+minus=new_split:down
keybind = alt+backslash=new_split:right

# --- Tab Management ---
keybind = cmd+r=prompt_tab_title
keybind = ctrl+semicolon=toggle_split_zoom

# --- Word Movement ---
keybind = alt+arrow_left=esc:b
keybind = alt+arrow_right=esc:f

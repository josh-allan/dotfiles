# Private overlay directory - never track (private repo stows here)
dot_config_common/.config/fish/private_user/

# Symlinks created by private repo stow into public repo directories
# These point to private/ (gitignored) so they're safe but untracked
dot_config_common/.config/fish/private_user
dot_home/scripts/mongodump.sh

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key


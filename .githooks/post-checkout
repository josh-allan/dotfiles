#!/usr/bin/env bash
set -euo pipefail

# post-checkout hook: regenerate agent configs after branch checkout
# This runs after `git checkout` or `git switch`.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SYNC_SCRIPT="$REPO_ROOT/private/opencode/.config/opencode/scripts/sync-agents.sh"

# Only run if the sync script exists
if [[ ! -f "$SYNC_SCRIPT" ]]; then
    exit 0
fi

# Only run on actual branch changes (not file checkouts)
PREV_HEAD="$1"
NEW_HEAD="$2"
CHECKOUT_TYPE="$3"  # 1 = branch, 0 = file

if [[ "$CHECKOUT_TYPE" == "0" ]]; then
    exit 0
fi

# Check if templates differ in the private repo
if ! git -C "$REPO_ROOT/private" diff --quiet "$PREV_HEAD" "$NEW_HEAD" -- \
    '.config/opencode/templates/' '.config/opencode/hosts/' '.config/opencode/scripts/sync-agents.sh' 2>/dev/null; then
    echo "[opencode] Agent templates changed. Regenerating configs..."
    cd "$REPO_ROOT/private/opencode/.config/opencode" && bash "$SYNC_SCRIPT"
fi

# --- BEGIN BEADS INTEGRATION v1.0.2 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run post-checkout "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'post-checkout' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run post-checkout "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'post-checkout'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.2 ---
